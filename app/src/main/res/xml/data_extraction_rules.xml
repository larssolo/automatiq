<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ (dataExtractionRules): same exclusions as backup_rules.xml for both cloud backup
     and device-to-device transfer. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="ai_settings.xml" />
        <exclude domain="sharedpref" path="ai_sent.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="ai_settings.xml" />
        <exclude domain="sharedpref" path="ai_sent.xml" />
    </device-transfer>
</data-extraction-rules>
